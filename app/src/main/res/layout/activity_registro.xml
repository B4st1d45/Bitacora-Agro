<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="REPORTE MENSUAL"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#FFD600"
            android:letterSpacing="0.1"
            android:layout_marginBottom="20dp"/>

        <!-- Selector de Mes Estilizado -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:weightSum="2">

                <Button
                    android:id="@+id/btnSeleccionarMes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="CAMBIAR MES"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#333333"
                    app:cornerRadius="4dp"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:id="@+id/tvMesSeleccionado"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ABRIL 2026"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Contenedor de Tabla con Elevación -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="4dp"
            app:cardElevation="4dp">

            <TableLayout
                android:id="@+id/tablaResumen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1E1E1E"
                android:padding="5dp"
                android:shrinkColumns="*">

                <TableRow android:background="#2C2C2C" android:paddingVertical="12dp">
                    <TextView android:text="FOLIO" android:textStyle="bold" android:textSize="10sp" android:layout_width="0dp" android:layout_weight="0.5" android:textColor="#FFD600" android:gravity="center"/>
                    <TextView android:text="FECHA" android:textStyle="bold" android:textSize="10sp" android:layout_width="0dp" android:layout_weight="0.8" android:textColor="#FFD600" android:gravity="center"/>
                    <TextView android:text="FUNDO" android:textStyle="bold" android:textSize="10sp" android:layout_width="0dp" android:layout_weight="1.2" android:textColor="#FFD600" android:gravity="center"/>
                    <TextView android:text="TAREA" android:textStyle="bold" android:textSize="10sp" android:layout_width="0dp" android:layout_weight="1.2" android:textColor="#FFD600" android:gravity="center"/>
                    <TextView android:text="CANT." android:textStyle="bold" android:textSize="10sp" android:layout_width="0dp" android:layout_weight="0.8" android:textColor="#FFD600" android:gravity="center"/>
                </TableRow>

                <!-- Aquí se inflarán las filas dinámicamente -->

            </TableLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnGenerarReporteMensual"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:text="EXPORTAR PDF MENSUAL"
            android:backgroundTint="#0D47A1"
            android:textColor="#FFFFFF"
            android:layout_marginTop="30dp"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:icon="@android:drawable/ic_menu_save"
            app:iconGravity="textStart"/>

    </LinearLayout>
</ScrollView>